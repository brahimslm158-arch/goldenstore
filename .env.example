# =====================================================
# Goldenstore — .env example (المتجر الحصري للتطبيقات المهكرة)
# انسخ هذا الملف إلى .env.local وعبّئ القيم
# على Vercel: أضف نفس المتغيرات في Project Settings → Environment Variables
# =====================================================

# ---------- المتجر ----------
STORE_NAME=Goldenstore
STORE_DOMAIN=goldenstore.me

# ---------- الإدارة ----------
# الدخول للإدارة عبر /admin بكلمة المرور فقط (اسم المستخدم ثابت على الخادم)
ADMIN_USERNAME=admin
# كلمة مرور قوية (لا تشاركها مع أحد) — هي الوسيلة الوحيدة للوصول إلى لوحة التحكّم
ADMIN_PASSWORD=ضع_كلمة_مرور_قوية_هنا
# نص عشوائي طويل (32+ حرفاً) لتوقيع رموز الجلسة JWT
# يمكنك توليده عبر: openssl rand -hex 32
JWT_SECRET=ضع_نصاً_عشوائياً_طويلاً_هنا_32_حرفاً_على_الأقل

# ---------- Firebase (Firestore) ----------
# من Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# انسخ القيم من ملف JSON الذي تحمّله
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
#
# المفتاح الخاص — الكود يقبل الصيغ التالية تلقائياً:
#   1) PEM كامل بأسطر حقيقية (مع علامات تنصيص اختيارية)
#   2) PEM بأسطر مهروبة على شكل \n (الشكل الافتراضي عند لصقه في Vercel)
#   3) مفتاح base64 — في هذه الحالة استخدم المتغيّر FIREBASE_PRIVATE_KEY_BASE64 بدلاً
#      (الأسهل: على لينكس/ماك  base64 -w0 service-account.json — ثم انسخ السلسلة)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"
# FIREBASE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTi...   # بديل أنظف لـ Vercel

# ---------- Cloudflare R2 ----------
# من Cloudflare Dashboard → R2 → Manage R2 API Tokens
# أنشئ API Token بصلاحيات Object Read & Write على bucket goldenstore-apks
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=goldenstore-apks

# الرابط العام لقراءة الملفات من R2
# الخيار الأسهل: فعّل Public Access على bucket وستحصل على رابط شبيه:
# https://pub-xxxxxxxxxxxxxxxx.r2.dev
# الخيار الأفضل: استخدم دومين مخصص (مثل cdn.goldenstore.me)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
